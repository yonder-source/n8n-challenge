    {
      "parameters": {
        "jsCode": "const raw = $json.output ?? $json.response ?? $json;\nlet parsed = raw;\nif (typeof raw === 'string') {\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    parsed = {};\n  }\n}\nconst category = parsed.category ?? 'Setup Question';\nconst routeTeam = parsed.route_team ?? (category === 'Pricing Question' ? 'sales' : 'support');\nconst needsEscalation = Boolean(parsed.needs_escalation) || $json.confidence_score < 0.78;\nconst confidence = Number(parsed.confidence ?? $json.confidence_score ?? 0.5);\nreturn [{\n  ...$json,\n  category,\n  route_team: routeTeam,\n  needs_escalation: needsEscalation,\n  confidence: Math.max(0, Math.min(1, confidence))\n}];"
      },
