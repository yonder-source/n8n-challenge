    {
      "parameters": {
        "jsCode": "const matches = $json.matches ?? $json.data ?? [];\nconst top1 = Number(matches?.[0]?.score ?? 0);\nconst top2 = Number(matches?.[1]?.score ?? 0);\nconst rerank = Number(matches?.[0]?.rerank_score ?? top1);\nconst score = 0.5 * top1 + 0.3 * (top1 - top2) + 0.2 * rerank;\nconst highRisk = Boolean($json.is_high_risk);\nreturn [{\n  ...$json,\n  retrieved_examples: matches.slice(0, 3),\n  sim_top1: top1,\n  sim_top2: top2,\n  rerank_score: rerank,\n  confidence_score: Math.max(0, Math.min(1, Number(score.toFixed(4)))),\n  should_use_tier2: highRisk || score < 0.78\n}];"
      },
