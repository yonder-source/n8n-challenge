    {
      "parameters": {
        "jsCode": "const payload = $json.body && typeof $json.body === 'object' ? $json.body : $json;\nconst from = (payload.from ?? payload.from_email ?? '').toString().trim();\nconst subjectRaw = (payload.subject ?? '').toString().trim();\nconst bodyRaw = (payload.body ?? '').toString().trim();\nconst subject = subjectRaw.replace(/^(re:|fwd:|fw:)\\s*/i, '').replace(/\\s+/g, ' ').trim();\nconst body = bodyRaw.replace(/\\r\\n/g, '\\n').replace(/\\r/g, '\\n').replace(/\\n{3,}/g, '\\n\\n').replace(/\\s+/g, ' ').trim().slice(0, 4000);\nconst combined = `${subject}\\n${body}`.toLowerCase();\nconst highRiskKeywords = ['soc 2', 'hipaa', 'baa', 'gdpr', 'dpa', 'contract', 'legal', 'security', 'encryption'];\nconst isHighRisk = highRiskKeywords.some((keyword) => combined.includes(keyword));\nreturn [{\n  from,\n  subject,\n  body,\n  query_text: `Subject: ${subject}\\nBody: ${body}`,\n  is_high_risk: isHighRisk,\n  received_at: new Date().toISOString()\n}];"
      },
      "id": "Code_Normalize",
      "name": "Normalize Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1080,
        280
      ]
