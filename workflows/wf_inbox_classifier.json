    {
      "parameters": {
        "jsCode": "const text = `${$json.subject}\\n${$json.body}`.toLowerCase();\nlet fastPath = false;\nlet category = '';\nlet routeTeam = 'support';\nlet needsEscalation = false;\nlet draftReply = '';\n\nif (/\\b(statement|checking account|bank account|monthly checking)\\b/.test(text)) {\n  fastPath = true;\n  category = 'Misdirected / Wrong Recipient';\n  routeTeam = 'none';\n  needsEscalation = false;\n  draftReply = 'Thanks for your message. This inbox belongs to Nexus Integrations support and appears to be the wrong recipient.';\n} else if (/\\b(recruiter|candidates available|schedule a call)\\b/.test(text)) {\n  fastPath = true;\n  category = 'Spam / Vendor Solicitation';\n  routeTeam = 'none';\n  needsEscalation = false;\n  draftReply = 'Thank you for reaching out. We are not exploring recruiter/vendor solicitations through this support channel at the moment.';\n}\n\nreturn [{ ...$json, fast_path: fastPath, fast_path_output: {\n  category,\n  draft_reply: draftReply,\n  confidence: fastPath ? 0.98 : 0,\n  needs_escalation: needsEscalation,\n  route_team: routeTeam,\n  evidence_refs: ['regex_fast_path']\n}}];"
      },
      "id": "Code_RuleSignals",
