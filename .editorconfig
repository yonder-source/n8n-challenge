root = true

[*.py]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
end_of_line = lf
insert_final_newline = true

[*.md]
charset = utf-8
trim_trailing_whitespace = false
end_of_line = lf
insert_final_newline = true

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2
end_of_line = lf
